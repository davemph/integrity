<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Integrity Assessment</title>

<style>

body{
    font-family:Arial,Helvetica,sans-serif;
    background:#f4f7f8;
    margin:0;
    padding:30px;
}

.container{
    max-width:1000px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 0 10px rgba(0,0,0,.15);
}

h1{
    color:#0b6b3a;
    text-align:center;
}

.question{
    margin-bottom:25px;
    padding-bottom:15px;
    border-bottom:1px solid #ddd;
}

.scale label{
    margin-right:18px;
    cursor:pointer;
    font-weight:bold;
}

button{
    background:#0b6b3a;
    color:white;
    border:none;
    padding:15px 35px;
    font-size:18px;
    border-radius:5px;
    cursor:pointer;
}

button:hover{
    background:#0a5b31;
}

#results{
    display:none;
    margin-top:30px;
    padding:20px;
    background:#eef9f2;
    border-left:6px solid green;
}

.score{
    font-size:30px;
    color:#0b6b3a;
    font-weight:bold;
}

</style>

</head>

<body>

<div class="container">

<h1>Integrity Assessment</h1>

<p><b>Instructions:</b> Rate yourself from <b>1 (Lowest)</b> to <b>5 (Highest)</b>.</p>

<form id="assessmentForm">

<script>

const questions=[
"I spend dedicated time in personal prayer every day.",
"I read and meditate on the Bible consistently and apply its teachings in my daily life.",
"I intentionally share the Gospel or my testimony with others whenever God provides an opportunity.",
"I willingly share my time, resources, or possessions with people who are genuinely in need.",
"I seek God's purpose and help others discover His plan for their lives rather than focusing only on immediate needs.",
"I faithfully give my tithes, offerings, or financial gifts as an act of worship and stewardship.",
"I remain loyal, trustworthy, and faithful in my relationships, even when it is difficult or costly.",
"My words, decisions, and actions are consistent with my Christian values both in public and in private.",
"When I make mistakes, I willingly admit them, seek forgiveness, and make every effort to correct them.",
"I strive to live with honesty, humility, and integrity, knowing that my life is a testimony to Christ."
];

document.write(questions.map((q,i)=>`

<div class="question">

<p><b>${i+1}. ${q}</b></p>

<div class="scale">

${[1,2,3,4,5].map(n=>`

<label>

<input type="radio" name="q${i}" value="${n}">

${n}

</label>

`).join("")}

</div>

</div>

`).join(""));

</script>

</form>

<br>

<button onclick="calculateScore()">Submit Assessment</button>

<div id="results">

<h2>Assessment Result</h2>

<p class="score" id="totalScore"></p>

<p id="percentage"></p>

<p id="rating"></p>

</div>

</div>

<script>

function calculateScore(){

let total=0;

for(let i=0;i<10;i++){

let answer=document.querySelector('input[name="q'+i+'"]:checked');

if(answer==null){

alert("Please answer Question "+(i+1));

return;

}

total+=parseInt(answer.value);

}

let percentage=((total/50)*100).toFixed(0);

let interpretation="";

if(total>=45){

interpretation="Excellent - You demonstrate outstanding biblical integrity.";

}
else if(total>=38){

interpretation="Strong - You have a solid biblical foundation with room for growth.";

}
else if(total>=30){

interpretation="Developing - Continue growing intentionally in these areas.";

}
else{

interpretation="Needs Attention - Prayerfully focus on strengthening these areas.";

}

document.getElementById("results").style.display="block";

document.getElementById("totalScore").innerHTML="Total Score : "+total+" / 50";

document.getElementById("percentage").innerHTML="<b>Percentage :</b> "+percentage+"%";

document.getElementById("rating").innerHTML="<b>Interpretation :</b><br>"+interpretation;

window.scrollTo({

top:document.body.scrollHeight,

behavior:'smooth'

});

}

</script>

</body>
</html>
